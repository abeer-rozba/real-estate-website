<div id="edit-page">
  <%- include("../partials/header.ejs") %>
  <br />
  <form action="/users/<%=user._id%>/edit?_method=PUT" method="POST">
    <input
      type="text"
      name="username"
      value="<%=user.username%>"
      required
    /><br />
    <input type="email" name="email" value="<%=user.email%>" required /><br />
    <button type="submit">Update</button>
  </form>

  <%- include("../partials/footer.ejs") %>
</div>
